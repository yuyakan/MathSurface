    "規則的な凹凸が並ぶ。最適化アルゴリズムのベンチマーク関数。": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Regelmäßige Hügel- und Talstruktur. Benchmark für Optimierungsalgorithmen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Regular array of bumps and dips. A benchmark for optimization algorithms."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Patrón regular de crestas y valles. Función de referencia para algoritmos de optimización."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "規則的な凹凸が並ぶ。最適化アルゴリズムのベンチマーク関数。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "규칙적인 요철이 나열됨. 최적화 알고리즘의 벤치마크 함수."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Padrão regular de elevações e depressões. Função de referência para algoritmos de otimização."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "规则排列的凹凸。优化算法的基准函数。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réseau régulier de bosses et de creux. Fonction de référence pour les algorithmes d’optimisation."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Schiera regolare di gobbe e avvallamenti. Funzione di benchmark per algoritmi di ottimizzazione."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "規則排列的凹凸。最佳化演算法的基準函數。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Регулярный массив бугров и впадин. Эталонная функция для алгоритмов оптимизации."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Rede regular de saliências e depressões. Função de referência para algoritmos de otimização."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مصفوفة منتظمة من النتوءات والانخفاضات. دالة معيارية لخوارزميات الأمثلة."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उभारों व गड्ढों की नियमित शृंखला। अनुकूलन एल्गोरिद्म का बेंचमार्क फलन।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
