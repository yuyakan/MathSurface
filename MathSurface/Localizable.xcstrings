    "入力された式によっては実際の数学的な軌跡と異なる表示になる場合があります": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Je nach Eingabe kann die Darstellung von der tatsächlichen mathematischen Ortskurve abweichen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Depending on the expression, the display may differ from the true mathematical locus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Según la expresión, la representación puede diferir del lugar geométrico real."
          }
