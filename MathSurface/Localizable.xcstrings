    "3方向に下がる特殊な鞍。高階の臨界点の代表例。": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein besonderer Sattel, der in drei Richtungen abfällt. Klassisches Beispiel eines kritischen Punkts höherer Ordnung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A special saddle descending in three directions. A classic higher-order critical point."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una silla especial que desciende en tres direcciones. Ejemplo clásico de punto crítico de orden superior."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "3方向に下がる特殊な鞍。高階の臨界点の代表例。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "세 방향으로 내려가는 특수한 안장. 고계 임계점의 대표 예."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma sela especial que desce em três direções. Exemplo clássico de ponto crítico de ordem superior."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向三个方向下降的特殊鞍点。高阶临界点的典型例子。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une selle spéciale descendant dans trois directions. Un point critique d’ordre supérieur classique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una sella speciale che scende in tre direzioni. Un classico punto critico di ordine superiore."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "向三個方向下降的特殊鞍面。高階臨界點的典型範例。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Особое седло, спадающее в трёх направлениях. Классическая критическая точка высокого порядка."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma sela especial que desce em três direções. Um ponto crítico de ordem superior clássico."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سرج خاص ينحدر في ثلاثة اتجاهات. مثال كلاسيكي لنقطة حرجة من رتبة عليا."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "तीन दिशाओं में उतरता एक विशेष सैडल। उच्च-कोटि क्रांतिक बिंदु का उत्कृष्ट उदाहरण।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pelana khusus yang menurun ke tiga arah. Contoh klasik titik kritis orde tinggi."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Üç yönde alçalan özel bir eyer. Yüksek dereceli kritik noktanın klasik örneği."
          }
        }
      }
    },
