    "cos は実数引数のみ": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "cos akzeptiert nur reelle Argumente"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "cos only accepts real arguments"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "cos solo acepta argumentos reales"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "cos は実数引数のみ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "cos는 실수 인자만 가능"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "cos aceita apenas argumentos reais"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "cos 仅接受实数参数"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "cos n’accepte que des arguments réels"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "cos accetta solo argomenti reali"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "cos 僅接受實數引數"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "cos принимает только вещественные аргументы"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "cos só aceita argumentos reais"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "cos يقبل الأعداد الحقيقية فقط"
          }
