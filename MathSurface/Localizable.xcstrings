    "原点から広がる同心円状の波。水面のリップル。": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konzentrische Wellen vom Ursprung – wie Wellen auf einer Wasseroberfläche."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Concentric ripples spreading from the origin, like ripples on water."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ondas concéntricas que se expanden desde el origen, como rizos en el agua."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "原点から広がる同心円状の波。水面のリップル。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "원점에서 퍼져 나가는 동심원 모양의 파동. 수면 잔물결."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ondas concêntricas que se espalham a partir da origem, como ondulações na água."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从原点向外扩散的同心圆波，仿佛水面涟漪。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ondulations concentriques se propageant depuis l’origine, comme des rides sur l’eau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Increspature concentriche che si propagano dall’origine, come onde sull’acqua."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從原點向外擴散的同心圓波紋，如水面漣漪。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
