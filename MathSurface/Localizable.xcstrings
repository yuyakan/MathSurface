        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "दूरी के साथ क्षय होता दोलन। वास्तविक भौतिक परिघटनाओं का मॉडल।"
          }
        },
        "id": {
          "stringUnit": {
